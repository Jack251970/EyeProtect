<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cmd="clr-namespace:Project1.UI.Controls.Commands"
    xmlns:controls="clr-namespace:Project1.UI.Controls"
    xmlns:s="clr-namespace:System;assembly=mscorlib">
    <!--  必须指定Key为WindowStyle，否则在切换主题时会找不到窗口样式！  -->
    <Style x:Key="WindowStyle" TargetType="{x:Type controls:Project1UIWindow}">
        <Setter Property="BorderThickness" Value="{DynamicResource WindowBorderThickness}" />
        <Setter Property="BorderBrush" Value="{DynamicResource WindowBorderBrush}" />
        <Setter Property="Background" Value="{DynamicResource WindowBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource FontBrush}" />
        <!--<Setter Property="TextOptions.TextRenderingMode" Value="Grayscale"/>-->
        <Setter Property="ResizeMode" Value="CanResizeWithGrip" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="WindowChrome.WindowChrome">
            <Setter.Value>
                <WindowChrome
                    CaptionHeight="{DynamicResource WindowTitleBarHeight}"
                    CornerRadius="0"
                    GlassFrameThickness="1"
                    NonClientFrameEdges="None"
                    UseAeroCaptionButtons="False" />
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:Project1UIWindow}">
                    <ControlTemplate.Resources>

                        <Storyboard x:Key="Storyboardload">
                            <DoubleAnimation
                                Storyboard.TargetName="WindowBorder"
                                Storyboard.TargetProperty="Opacity"
                                From="0"
                                To="1"
                                Duration="00:00:0.1" />
                        </Storyboard>

                    </ControlTemplate.Resources>
                    <Border x:Name="WindowBorder" Margin="{Binding Source={x:Static SystemParameters.WindowNonClientFrameThickness}}">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <AdornerDecorator>
                                <Grid x:Name="WindowContent">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />

                                    </Grid.RowDefinitions>

                                    <!--  标题栏  -->
                                    <Grid x:Name="TitleBar" Height="{DynamicResource WindowTitleBarHeight}">
                                        <Grid.Background>
                                            <LinearGradientBrush Opacity="0.1" StartPoint="0.5,0" EndPoint="0.5,1">
                                                <GradientStop Offset="0" Color="{DynamicResource ThemeColor}" />
                                                <GradientStop Offset="1" Color="Transparent" />
                                            </LinearGradientBrush>
                                        </Grid.Background>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />

                                            <ColumnDefinition Width="*" />

                                        </Grid.ColumnDefinitions>
                                        <Grid Grid.Column="0" WindowChrome.IsHitTestVisibleInChrome="True">
                                            <!--  LOGO区域  -->


                                            <Image
                                                Width="16"
                                                Height="16"
                                                Margin="7,0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Source="{TemplateBinding Icon}" />
                                        </Grid>
                                        <!--  导航栏区域  -->
                                        <Grid
                                            x:Name="NavigationViewGrid"
                                            Grid.Column="1"
                                            Panel.ZIndex="3"
                                            WindowChrome.IsHitTestVisibleInChrome="True">
                                            <ContentControl
                                                x:Name="NavigationView"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Content="{TemplateBinding NavigationView}" />
                                        </Grid>
                                        <Grid Grid.Column="2" Panel.ZIndex="3">
                                            <!--  标题区域  -->
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontWeight="Bold"
                                                Text="{TemplateBinding Title}" />

                                        </Grid>
                                        <Grid
                                            Grid.Column="3"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Panel.ZIndex="3"
                                            WindowChrome.IsHitTestVisibleInChrome="True">
                                            <!--  系统按钮区域  -->

                                            <StackPanel Orientation="Horizontal">
                                                <!--  最小化  -->
                                                <Button
                                                    Width="34"
                                                    Height="26"
                                                    Command="{x:Static cmd:Project1UIWindowCommands.MinimizeWindowCommand}"
                                                    Content="&#xE921;"
                                                    Style="{DynamicResource WindowSystemButton}"
                                                    ToolTip="最小化"
                                                    Visibility="{TemplateBinding MinimizeVisibility}" />
                                                <!--  最大化  -->
                                                <Button
                                                    x:Name="MaximizeButton"
                                                    Width="34"
                                                    Height="26"
                                                    Command="{x:Static cmd:Project1UIWindowCommands.MaximizeWindowCommand}"
                                                    Content="&#xE922;"
                                                    Style="{DynamicResource WindowSystemButton}"
                                                    ToolTip="最大化"
                                                    Visibility="{TemplateBinding MaximizeVisibility}" />
                                                <!--  还原  -->
                                                <Button
                                                    x:Name="RestoreButton"
                                                    Width="34"
                                                    Height="26"
                                                    Command="{x:Static cmd:Project1UIWindowCommands.RestoreWindowCommand}"
                                                    Content="&#xE923;"
                                                    Style="{DynamicResource WindowSystemButton}"
                                                    ToolTip="向下还原"
                                                    Visibility="Collapsed" />
                                                <!--  关闭  -->
                                                <Button
                                                    Width="34"
                                                    Height="26"
                                                    Command="{x:Static cmd:Project1UIWindowCommands.CloseWindowCommand}"
                                                    Content="&#xE8BB;"
                                                    Style="{DynamicResource WindowSystemButton}"
                                                    ToolTip="关闭"
                                                    Visibility="{TemplateBinding CloseVisibility}" />

                                            </StackPanel>


                                        </Grid>
                                    </Grid>



                                    <!--  窗体内容  -->
                                    <ContentPresenter Grid.Row="1" Panel.ZIndex="2" />

                                </Grid>
                            </AdornerDecorator>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="WindowState" Value="Normal" />
                                <Condition Property="MaximizeVisibility" Value="Visible" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="MaximizeButton" Property="Visibility" Value="Visible" />
                            <Setter TargetName="RestoreButton" Property="Visibility" Value="Collapsed" />
                        </MultiTrigger>
                        <Trigger Property="WindowState" Value="Maximized">
                            <!--  最大化时调整外边距，否则显示不完整  -->
                            <Setter TargetName="WindowContent" Property="Margin" Value="7" />
                            <Setter TargetName="MaximizeButton" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="RestoreButton" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <!--<Trigger Property="WindowState" Value="Normal">
                            <Setter TargetName="MaximizeButton" Property="Visibility" Value="Visible" />
                            <Setter TargetName="RestoreButton" Property="Visibility" Value="Collapsed" />
                        </Trigger>-->
                        <!--<EventTrigger RoutedEvent="Window.Loaded">
                        -->
                        <!--  窗口载入动画  -->
                        <!--
                            <BeginStoryboard Storyboard="{StaticResource Storyboardload}">
                            </BeginStoryboard>

                        </EventTrigger>-->
                        <Trigger Property="WindowStyle" Value="None">
                            <Setter TargetName="WindowBorder" Property="Margin" Value="0" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter TargetName="TitleBar" Property="Visibility" Value="Collapsed" />
                            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
                            <!--<Setter Property="BorderBrush" Value="Transparent" />-->
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

    </Style>


</ResourceDictionary>