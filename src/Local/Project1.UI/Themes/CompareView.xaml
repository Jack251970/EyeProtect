<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Project1.UI.Controls"
    xmlns:converter="clr-namespace:Project1.UI.Controls.Converters">
    <converter:StringConverter x:Key="StringConverter" />
    <Style TargetType="{x:Type controls:CompareView}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="SnapsToDevicePixels" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:CompareView}">
                    <Grid>
                        <Popup
                            x:Name="Popup"
                            AllowsTransparency="True"
                            HorizontalOffset="-10"
                            Placement="Top"
                            PlacementTarget="{Binding ElementName=Border}">
                            <Border
                                x:Name="PopupBorder"
                                Margin="15"
                                Padding="10"
                                Background="White"
                                BorderBrush="#ccc"
                                BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="5"
                                        Opacity="0.2"
                                        ShadowDepth="1" />
                                </Border.Effect>
                                <Grid>
                                    <TextBlock x:Name="PopupText" />
                                    <Path
                                        Width="15"
                                        Height="15"
                                        Margin="-5,0,0,-25"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Bottom"
                                        Data="M 0 0 L 7.5 7.5 L 15 0"
                                        Fill="White"
                                        SnapsToDevicePixels="False"
                                        Stroke="#ccc"
                                        StrokeThickness="1" />
                                </Grid>

                            </Border>
                        </Popup>
                        <Border
                            x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,10,0"
                                    FontSize="26"
                                    FontWeight="Bold"
                                    Text="{TemplateBinding DataB,
                                                           Converter={StaticResource StringConverter}}" />
                                <TextBlock
                                    x:Name="UPIcon"
                                    Margin="0,5,0,0"
                                    FontFamily="/Project1.UI;component/Assets/IconFonts/#Fabric External MDL2 Assets"
                                    FontSize="10"
                                    Foreground="{TemplateBinding UPColor}"
                                    Text="&#xEECC;"
                                    Visibility="Collapsed" />
                                <TextBlock
                                    x:Name="DownIcon"
                                    Margin="0,5,0,0"
                                    FontFamily="/Project1.UI;component/Assets/IconFonts/#Fabric External MDL2 Assets"
                                    FontSize="10"
                                    Foreground="{TemplateBinding DownColor}"
                                    Text="&#xEECD;"
                                    Visibility="Collapsed" />
                                <TextBlock
                                    x:Name="NoCIcon"
                                    Margin="0,5,0,0"
                                    FontFamily="/Project1.UI;component/Assets/IconFonts/#Fabric External MDL2 Assets"
                                    FontSize="10"
                                    Foreground="{TemplateBinding NoChangeColor}"
                                    Text="&#xEC11;"
                                    Visibility="Collapsed" />
                                <TextBlock
                                    x:Name="DiffValue"
                                    Margin="5,0,0,0"
                                    FontSize="14"
                                    Foreground="{TemplateBinding Foreground}">
                                    <Run Text="{TemplateBinding DiffValue, Converter={StaticResource StringConverter}}" /><Run Text="%" />
                                </TextBlock>

                            </StackPanel>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Popup" Property="IsOpen" Value="true" />
                        </MultiTrigger>
                        <Trigger Property="DiffValueStatus" Value="Up">
                            <Setter TargetName="UPIcon" Property="Visibility" Value="Visible" />


                        </Trigger>
                        <Trigger Property="DiffValueStatus" Value="Down">
                            <Setter TargetName="DownIcon" Property="Visibility" Value="Visible" />

                        </Trigger>
                        <Trigger Property="DiffValueStatus" Value="NoChange">
                            <Setter TargetName="NoCIcon" Property="Visibility" Value="Visible" />

                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

    </Style>


</ResourceDictionary>