<ui:Project1UIWindow
    x:Class="ProjectEye.Views.OptionsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ProjectEye.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="clr-namespace:Project1.UI.Controls;assembly=Project1.UI"
    Title="{DynamicResource Lang_Settings}"
    Width="580"
    Height="400"
    Icon="/ProjectEye;component/Resources/sunglasses.ico"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <ui:Project1UIWindow.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FontBrush}" />
        </Style>
    </ui:Project1UIWindow.Resources>
    <ui:Project1UIWindow.ExtElement>
        <ui:Project1UIModal Show="{Binding Model.ShowModal, Mode=TwoWay}">
            <Border
                Margin="10"
                Padding="10,15"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource WindowBackground}"
                CornerRadius="2">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="5"
                        Opacity="0.3"
                        ShadowDepth="0" />
                </Border.Effect>

                <TextBlock Text="{Binding Model.ModalText}" />
            </Border>
        </ui:Project1UIModal>
    </ui:Project1UIWindow.ExtElement>
    <Grid Margin="5">

        <TabControl Margin="0,0,0,50">
            <TabItem Header="{DynamicResource Lang_General}">
                <ScrollViewer>
                    <StackPanel Margin="10">

                        <!--<Grid Margin="0,10,0,0">-->
                        <!--<Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="10*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                            </Grid.RowDefinitions>-->
                        <!--  提醒间隔  -->
                        <!--<StackPanel>
                                <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center" Text="{DynamicResource Lang_Notificationinterval}"></TextBlock>

                                <Slider
                                Grid.Row="0"
                                VerticalAlignment="Center"
                                Grid.Column="1" Maximum="420" Minimum="1" SmallChange="1" Value="{Binding Model.Data.General.WarnTime}" />
                                <TextBlock
                                Grid.Row="0"
                                   Grid.Column="2"
                                   HorizontalAlignment="Right"
                                Margin="10,0,0,0"
                                   VerticalAlignment="Center">
                                <Run Text="{Binding Model.Data.General.WarnTime}"/>
                                <Run Text="{DynamicResource Lang_Minutes}"/>
                                </TextBlock>
                            </StackPanel>-->

                        <Slider
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="0,0,0,0"
                            VerticalAlignment="Center"
                            Maximum="420"
                            Minimum="1"
                            SmallChange="1"
                            Tag="{DynamicResource Lang_Notificationinterval}"
                            ToolTip="{DynamicResource Lang_Minutes}"
                            Value="{Binding Model.Data.General.WarnTime}" />


                        <!--<StackPanel>-->

                        <!--  休息时长  -->
                        <Slider
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="0,20,0,0"
                            VerticalAlignment="Center"
                            Maximum="300"
                            Minimum="1"
                            SmallChange="1"
                            Tag="{DynamicResource Lang_Breaktimelength}"
                            ToolTip="{DynamicResource Lang_Seconds}"
                            Value="{Binding Model.Data.General.RestTime}" />
                        <!--<TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center" Text="{DynamicResource Lang_Breaktimelength}"></TextBlock>
                                <Slider
                                Grid.Row="1"
                                VerticalAlignment="Center"
                                Grid.Column="1" Maximum="300" Minimum="1" SmallChange="1" Value="{Binding Model.Data.General.RestTime}" />
                                <TextBlock
                                Grid.Row="1"
                                   Grid.Column="2"
                                   HorizontalAlignment="Right"
                                Margin="10,0,0,0"
                                   VerticalAlignment="Center">
                                <Run Text="{Binding Model.Data.General.RestTime}"/>
                                <Run Text="{DynamicResource Lang_Seconds}"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>-->
                        <ui:Toggle
                            Margin="0,20,0,0"
                            Cursor="Hand"
                            IsChecked="{Binding Model.Data.General.Startup}"
                            Text="{DynamicResource Lang_Autostartatboot}" />
                        <ui:Toggle
                            Margin="0,20,0,0"
                            Cursor="Hand"
                            IsChecked="{Binding Model.Data.General.Sound}"
                            Text="{DynamicResource Lang_Soundforbreakend}" />
                        <Grid Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>
                            <!--<TextBlock Grid.Column="0"
                                   Margin="0,0,10,0" VerticalAlignment="Center">自定义提示音</TextBlock>-->

                            <ui:Project1UIInput
                                Grid.Column="1"
                                Width="auto"
                                ExtNames=".wav|*.wav"
                                Icon="MusicNote"
                                Placeholder="{DynamicResource Lang_Leaveblankfordefault}"
                                Text="{Binding Model.Data.General.SoundPath}"
                                TextWrapping="NoWrap"
                                Type="FileSelect" />
                            <ui:Project1UIButton
                                Grid.Column="2"
                                Margin="5,0,0,0"
                                Command="{Binding soundTestCommand}"
                                Content="{DynamicResource Lang_Preview}"
                                Style="{DynamicResource basic}" />
                        </Grid>
                        <!--<CheckBox Content="离开监听" IsChecked="{Binding Model.Data.General.LeaveListener}" Margin="0,10,0,0" Cursor="Hand" ToolTip="如果你离开了电脑我会停止计时直到你回来，且不需要你进行任何操作哦！"/>-->

                        <!--<CheckBox Content="{DynamicResource Lang_Statisticsanalysis}" IsChecked="{Binding Model.Data.General.IsWeekDataAnalysis}" Margin="0,10,0,0" Cursor="Hand"
                              />-->
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="{DynamicResource Lang_Display}">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />

                            </Grid.RowDefinitions>
                            <!--  语言  -->
                            <TextBlock
                                Grid.Column="0"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="{DynamicResource Lang_Language}" />
                            <ComboBox
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                DisplayMemberPath="DisplayName"
                                ItemsSource="{Binding Model.Languages}"
                                SelectedItem="{Binding Model.Data.Style.Language}"
                                SelectedValue="{Binding Model.Data.Style.Language.Value}"
                                SelectedValuePath="Value" />

                            <!--  主题  -->
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="{DynamicResource Lang_Theme}" />
                            <ComboBox
                                Grid.Row="1"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                DisplayMemberPath="DisplayName"
                                ItemsSource="{Binding Model.Themes}"
                                SelectedItem="{Binding Model.Data.Style.Theme}"
                                SelectedValue="{Binding Model.Data.Style.Theme.ThemeName}"
                                SelectedValuePath="ThemeName" />

                            <!--  全屏提示窗口动画  -->
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="{DynamicResource Lang_Fullscreennotificationanimation}" />
                            <ComboBox
                                Name="cb"
                                Grid.Row="2"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                DisplayMemberPath="DisplayName"
                                ItemsSource="{Binding Model.Animations}"
                                SelectedItem="{Binding Model.Data.Style.TipWindowAnimation}"
                                SelectedValue="{Binding Model.Data.Style.TipWindowAnimation.ID}"
                                SelectedValuePath="ID" />

                            <!--  全屏提示窗口自定义  -->
                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="0"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="{DynamicResource Lang_Fullscreennotificationappearance}" />
                            <ui:Project1UIButton
                                Grid.Row="3"
                                Grid.Column="1"
                                HorizontalAlignment="Left"
                                Command="{Binding openWindowCommand}"
                                CommandParameter="TipViewDesignWindow"
                                Content="{DynamicResource Lang_Customize}"
                                Style="{DynamicResource basic}" />
                        </Grid>

                        <ui:Toggle
                            Margin="0,10,0,0"
                            Cursor="Hand"
                            IsChecked="{Binding Model.IsAutoDark}"
                            Text="{DynamicResource Lang_Switchtodarkthemeautomatically}" />
                        <Grid Margin="0,10,0,0" Visibility="{Binding Model.AutoDarkConfigVisibility}">
                            <!--  自动切换深色模式配置  -->
                            <StackPanel Margin="30,0,0,0">
                                <TextBlock Text="{DynamicResource Lang_Specifythetime}" />
                                <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                    <ui:TimeBox Hour="{Binding Model.Data.Style.AutoDarkStartH, Mode=TwoWay}" Minutes="{Binding Model.Data.Style.AutoDarkStartM, Mode=TwoWay}" />
                                    <TextBlock
                                        Margin="5,0"
                                        VerticalAlignment="Center"
                                        Text=" " />
                                    <ui:TimeBox Hour="{Binding Model.Data.Style.AutoDarkEndH, Mode=TwoWay}" Minutes="{Binding Model.Data.Style.AutoDarkEndM, Mode=TwoWay}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <ui:Toggle
                            Margin="0,20,0,0"
                            Cursor="Hand"
                            IsChecked="{Binding Model.IsTipAsk, Mode=TwoWay}"
                            Text="{DynamicResource Lang_Showbuttonsinfullscreennotification}" />
                        <ui:Toggle
                            Margin="0,10,0,0"
                            Cursor="Hand"
                            IsChecked="{Binding Model.Data.Style.IsThruTipWindow, Mode=TwoWay}"
                            IsEnabled="{Binding Model.IsThruTipWindowEnabled}"
                            Text="{DynamicResource Lang_Enablemousepassthroughduringfullscreennotification}" />

                        <ui:Toggle
                            Margin="0,20,0,0"
                            Cursor="Hand"
                            IsChecked="{Binding Model.Data.Style.IsAnimation, Mode=TwoWay}"
                            Text="{DynamicResource Lang_Enableanimation}" />


                        <ui:Toggle
                            Margin="0,20,0,0"
                            Cursor="Hand"
                            IsChecked="{Binding Model.IsPreAlert}"
                            Text="{DynamicResource Lang_Earlypopupforbreaktime}" />
                        <Grid Margin="0,10,0,0" Visibility="{Binding Model.PreAlertConfigVisibility}">
                            <!--  预提醒配置  -->
                            <StackPanel Margin="30,0,0,0">
                                <!--  预提醒提示音  -->
                                <CheckBox
                                    Margin="0,0,0,0"
                                    Content="{DynamicResource Lang_Popupsound}"
                                    Cursor="Hand"
                                    IsChecked="{Binding Model.Data.Style.IsPreAlertSound}" />
                                <!--  预提醒提前时间  -->
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Top"
                                        Text="{DynamicResource Lang_Popupleadtime}" />

                                    <Grid Grid.Column="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="auto" />
                                        </Grid.ColumnDefinitions>
                                        <Slider
                                            Grid.Column="0"
                                            Maximum="60"
                                            Minimum="3"
                                            SmallChange="1"
                                            ToolTip="{DynamicResource Lang_Seconds}"
                                            Value="{Binding Model.Data.Style.PreAlertTime}" />
                                        <!--<TextBlock Grid.Column="2" Margin="10,0,0,0">
                                            <Run Text="{Binding Model.Data.Style.PreAlertTime}"/>
                                            <Run Text="{DynamicResource Lang_Seconds}"/>
                                        </TextBlock>-->
                                    </Grid>
                                </Grid>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        Text="{DynamicResource Lang_Defaultactionafterthepopup}" />
                                    <ComboBox
                                        Grid.Column="1"
                                        DisplayMemberPath="DisplayName"
                                        ItemsSource="{Binding Model.PreAlertActions}"
                                        SelectedItem="{Binding Model.Data.Style.PreAlertAction}"
                                        SelectedValue="{Binding Model.Data.Style.PreAlertAction.Value}"
                                        SelectedValuePath="Value" />


                                </Grid>
                                <!--  预提醒的弹窗内容配置  -->
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        Text="{DynamicResource Lang_Icon}" />

                                    <ui:Project1UIInput
                                        Grid.Column="1"
                                        Width="auto"
                                        ExtNames=".jpg|*.jpg|.png|*.png"
                                        Placeholder="{DynamicResource Lang_Leaveblankfordefault}"
                                        Text="{Binding Model.Data.Style.PreAlertIcon}"
                                        TextWrapping="NoWrap"
                                        Type="FileSelect" />
                                </Grid>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        Text="{DynamicResource Lang_Title}" />

                                    <ui:Project1UIInput
                                        Grid.Column="1"
                                        Width="auto"
                                        VerticalContentAlignment="Center"
                                        Placeholder=""
                                        Text="{Binding Model.Data.Style.PreAlertTitle}"
                                        Type="Text" />

                                </Grid>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        Text="{DynamicResource Lang_Subtitle}" />

                                    <ui:Project1UIInput
                                        Grid.Column="1"
                                        Width="auto"
                                        VerticalContentAlignment="Center"
                                        Placeholder=""
                                        Text="{Binding Model.Data.Style.PreAlertSubtitle}"
                                        Type="Text" />

                                </Grid>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Top"
                                        Text="{DynamicResource Lang_Content}" />
                                    <StackPanel Grid.Column="1">
                                        <ui:Project1UIInput
                                            Width="auto"
                                            Height="40"
                                            VerticalContentAlignment="Top"
                                            AcceptsReturn="True"
                                            Text="{Binding Model.Data.Style.PreAlertMessage}"
                                            TextWrapping="Wrap"
                                            Type="Text" />
                                        <TextBlock
                                            Foreground="#FF838383"
                                            Text="{DynamicResource Lang_Variablesdescription}"
                                            TextWrapping="Wrap" />
                                    </StackPanel>


                                </Grid>
                            </StackPanel>
                        </Grid>

                        <TextBlock
                            Margin="0,20,0,0"
                            FontSize="14"
                            FontWeight="Bold"
                            Text="{DynamicResource Lang_StatisticsWindow}" />
                        <TextBlock Margin="0,15,0,0" Text="{DynamicResource Lang_DataWindowWorkTimeImagePath}" />
                        <ui:Project1UIInput
                            Width="auto"
                            Margin="0,10,0,0"
                            ExtNames=".jpg|*.jpg|.png|*.png"
                            Icon="Photo"
                            Placeholder="{DynamicResource Lang_Leaveblankfordefault}"
                            Text="{Binding Model.Data.Style.DataWindowWorkTimeImagePath}"
                            TextWrapping="NoWrap"
                            Type="FileSelect" />
                        <TextBlock Margin="0,15,0,0" Text="{DynamicResource Lang_DataWindowRestTimeImagePath}" />
                        <ui:Project1UIInput
                            Width="auto"
                            Margin="0,10,0,0"
                            ExtNames=".jpg|*.jpg|.png|*.png"
                            Icon="Photo"
                            Placeholder="{DynamicResource Lang_Leaveblankfordefault}"
                            Text="{Binding Model.Data.Style.DataWindowRestTimeImagePath}"
                            TextWrapping="NoWrap"
                            Type="FileSelect" />
                        <TextBlock Margin="0,15,0,0" Text="{DynamicResource Lang_DataWindowSkipImagePath}" />
                        <ui:Project1UIInput
                            Width="auto"
                            Margin="0,10,0,0"
                            ExtNames=".jpg|*.jpg|.png|*.png"
                            Icon="Photo"
                            Placeholder="{DynamicResource Lang_Leaveblankfordefault}"
                            Text="{Binding Model.Data.Style.DataWindowSkipImagePath}"
                            TextWrapping="NoWrap"
                            Type="FileSelect" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="{DynamicResource Lang_Hotkeys}">
                <StackPanel Margin="10">
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40" />
                            <RowDefinition Height="40" />
                        </Grid.RowDefinitions>
                        <!--  进入休息  -->
                        <TextBlock
                            Grid.Column="0"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            Text="{DynamicResource Lang_Startthebreak}" />
                        <ui:Project1UIKeyboardInput
                            Grid.Column="1"
                            Width="auto"
                            KeyText="{Binding Model.Data.KeyboardShortcuts.Reset, Mode=TwoWay}"
                            Placeholder="{DynamicResource Lang_Pleasepressakey}" />
                        <!--  跳过休息  -->
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            Text="{DynamicResource Lang_Skipthebreak}" />
                        <ui:Project1UIKeyboardInput
                            Grid.Row="1"
                            Grid.Column="1"
                            Width="auto"
                            KeyText="{Binding Model.Data.KeyboardShortcuts.NoReset, Mode=TwoWay}"
                            Placeholder="{DynamicResource Lang_Pleasepressakey}" />
                    </Grid>

                </StackPanel>
            </TabItem>
            <TabItem Header="{DynamicResource Lang_Behaviors}">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <ui:Toggle
                            Margin="0,20,0,0"
                            Cursor="Hand"
                            IsChecked="{Binding Model.Data.Behavior.IsHandleTimeoutRest}"
                            Text="{DynamicResource Lang_HandleTimeoutAutoRest}" />
                        <ui:Toggle
                            Margin="0,10,0,0"
                            Cursor="Hand"
                            IsChecked="{Binding Model.Data.Behavior.IsDisabledSkip}"
                            Text="{DynamicResource Lang_Breakscannotbeskipped}" />
                        <ui:Toggle
                            Margin="0,20,0,0"
                            Cursor="Hand"
                            IsChecked="{Binding Model.Data.Behavior.IsFullScreenBreak}"
                            Text="{DynamicResource Lang_Donotdisturbwhenrunningfullscreenapplications}" />
                        <ui:Toggle
                            Margin="0,20,0,0"
                            Cursor="Hand"
                            IsChecked="{Binding Model.IsBreakProgressList, Mode=TwoWay}"
                            Text="{DynamicResource Lang_Donotdisturbwhenfollowingprocessesarerunning}" />
                        <Grid Margin="0,10,0,0" Visibility="{Binding Model.BreakProgressListVisibility}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30" />
                                <RowDefinition Height="150" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="100" />
                                </Grid.ColumnDefinitions>
                                <ui:Project1UIInput
                                    Name="breakProcessTextbox"
                                    Width="auto"
                                    MinHeight="23"
                                    VerticalContentAlignment="Center"
                                    Placeholder="{DynamicResource Lang_Processname}"
                                    Type="Text" />
                                <ui:Project1UIButton
                                    Grid.Column="1"
                                    MinWidth="85"
                                    MinHeight="23"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Command="{Binding addBreackProcessCommand}"
                                    CommandParameter="{Binding ElementName=breakProcessTextbox, Path=Text}"
                                    Content="{DynamicResource Lang_Add}"
                                    Style="{DynamicResource basic}" />
                            </Grid>
                            <ListView
                                Name="breakProcessListView"
                                Grid.Row="1"
                                Margin="0,10,0,0"
                                ItemsSource="{Binding Model.Data.Behavior.BreakProgressList, Mode=TwoWay}"
                                SelectedItem="{Binding Model.SelectedItem}"
                                SelectionMode="Single">

                                <ListView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Command="{Binding removeBreackProcessCommand}" Header="{DynamicResource Lang_Remove}" />
                                    </ContextMenu>
                                </ListView.ContextMenu>

                                <ListView.View>
                                    <GridView>
                                        <GridView.Columns>
                                            <GridViewColumn Width="{Binding ElementName=breakProcessListView, Path=ActualWidth}">
                                                <GridViewColumn.Header>
                                                    <TextBlock
                                                        Width="{Binding ElementName=breakProcessListView, Path=ActualWidth}"
                                                        HorizontalAlignment="Left"
                                                        Text="{DynamicResource Lang_Processname}" />
                                                </GridViewColumn.Header>
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Grid Width="auto">
                                                            <TextBlock
                                                                Width="{Binding ElementName=breakProcessListView, Path=ActualWidth}"
                                                                HorizontalAlignment="Left"
                                                                Text="{Binding}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>

                                        </GridView.Columns>

                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{DynamicResource Lang_About}">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <Image
                            Height="30"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Left"
                            RenderTransformOrigin="0.5,0.5"
                            Source="/ProjectEye;component/Resources/sunglasses.ico">
                            <Image.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Image.RenderTransform>
                            <Image.Triggers>
                                <EventTrigger RoutedEvent="MouseDown">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)">
                                                <EasingDoubleKeyFrame KeyTime="0:0:.1" Value="1.5" />
                                                <EasingDoubleKeyFrame KeyTime="0:0:.4" Value="1" />

                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)">

                                                <EasingDoubleKeyFrame KeyTime="0:0:.1" Value="1.5" />
                                                <EasingDoubleKeyFrame KeyTime="0:0:.4" Value="1" />

                                            </DoubleAnimationUsingKeyFrames>
                                            <!--<DoubleAnimation  Duration="0:0:.3" To="1.5" Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)" AutoReverse="True"/>
                                            <DoubleAnimation Duration="0:0:.3" To="1.5" Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)" AutoReverse="True"/>-->
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Image.Triggers>
                        </Image>
                        <TextBlock
                            Margin="0,10,0,0"
                            FontWeight="Bold"
                            Text="Project Eye"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Margin="0,10,0,0"
                            Opacity=".5"
                            Text="{DynamicResource Lang_Aprogramwhichprotectsyoureyesbehindthescenes}"
                            TextWrapping="Wrap" />
                        <TextBlock Margin="0,10,0,0" TextWrapping="Wrap"><Run Text="{DynamicResource Lang_Version}" /> <Hyperlink Command="{Binding openurlCommand}" CommandParameter="{Binding Model.VersionLink}">
                                <Run Text="{Binding Model.Version}" />
                            </Hyperlink> <Hyperlink Command="{Binding updateCommand}">
                                <Run Text="{DynamicResource Lang_Checkforupdates}" />
                            </Hyperlink></TextBlock>

                        <!--<Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="40"/>
                            </Grid.RowDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Text="{DynamicResource Lang_Help}"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                TextWrapping="WrapWithOverflow"
                                VerticalAlignment="Center"
                                Foreground="#4f6bed"
                                Cursor="Hand"
                                Text="https://littlepanda.gitbook.io/project-eye"
