<ui:Project1UIWindow
    x:Class="ProjectEye.Views.StatisticWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:chart="clr-namespace:Project1.UI.Controls.ChartControl;assembly=Project1.UI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:date="clr-namespace:Project1.UI.Controls.DatePicker;assembly=Project1.UI"
    xmlns:local="clr-namespace:ProjectEye.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="clr-namespace:Project1.UI.Controls;assembly=Project1.UI"
    Title="{DynamicResource Lang_Statistics}"
    Width="800"
    Height="600"
    Icon="/ProjectEye;component/Resources/sunglasses.ico"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <ui:Project1UIWindow.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FontBrush}" />
        </Style>
        <Style x:Key="DataCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,20,0,0" />
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Grid>
                            <TextBlock Text="123" />
                            <!--<ContentPresenter

                                        x:Name="IconContent"
                                        Grid.Column="1"

                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                       HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />-->
                        </Grid>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <DropShadowEffect
                    x:Key="CardShadow"
                    BlurRadius="12"
                    Direction="0"
                    Opacity=".3"
                    RenderingBias="Performance"
                    ShadowDepth="0" />

            </Style.Resources>

            <Style.Triggers>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True" />
                    </MultiTrigger.Conditions>
                    <MultiTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="Opacity"
                                    To="1"
                                    Duration="0:0:0.15" />
                            </Storyboard>
                        </BeginStoryboard>
                    </MultiTrigger.EnterActions>
                    <MultiTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard FillBehavior="Stop">
                                <ColorAnimation
                                    Storyboard.TargetProperty="Background.Color"
                                    To="#008"
                                    Duration="0:0:0.3" />
                            </Storyboard>
                        </BeginStoryboard>
                    </MultiTrigger.ExitActions>
                </MultiTrigger>
            </Style.Triggers>
        </Style>
    </ui:Project1UIWindow.Resources>

    <ui:Project1UIWindow.ExtElement>
        <ui:Project1UIModal
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch"
            ClickClose="False"
            Show="{Binding Data.IsShowOnboarding, Mode=TwoWay}"
            Duration="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="9*" />
                    <RowDefinition Height="1*" />

                </Grid.RowDefinitions>
                <Border
                    Margin="80,50"
                    Background="White"
                    CornerRadius="2"
                    Opacity=".98">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="5"
                            Opacity="0.3"
                            ShadowDepth="0" />
                    </Border.Effect>
                    <ScrollViewer>
                        <StackPanel Margin="10" HorizontalAlignment="Center">
                            <Image
                                Height="80"
                                Margin="0,20"
                                Source="/ProjectEye;component/Resources/ecology.png" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="24"
                                Text="欢迎来到全新的数据统计页，看看有哪些改动吧！" />

                            <Grid Margin="0,20,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4*" />
                                    <ColumnDefinition Width="6*" />

                                </Grid.ColumnDefinitions>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="18"
                                        FontWeight="Bold"
                                        Text="存储时间" />
                                    <Image
                                        Height="80"
                                        Margin="0,20,0,0"
                                        Source="/ProjectEye;component/Resources/files_and_folder.png" />
                                </StackPanel>
                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Text="从现在开始将不限制数据保留天数，您的数据将永久保存在本地。"
                                    TextWrapping="WrapWithOverflow" />
                            </Grid>

                            <Grid Margin="0,20,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="6*" />
                                    <ColumnDefinition Width="4*" />

                                </Grid.ColumnDefinitions>
                                <StackPanel
                                    Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="18"
                                        FontWeight="Bold"
                                        Text="全新的UI" />
                                    <Image
                                        Height="80"
                                        Margin="0,20,0,0"
                                        Source="/ProjectEye;component/Resources/creative_process_.png" />
                                </StackPanel>
                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Text="不仅重新设计了图表的UI视觉，还加入了图表动效，让数据不那么冰冷单调。"
                                    TextWrapping="WrapWithOverflow" />
                            </Grid>
                            <Grid Margin="0,20,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4*" />
                                    <ColumnDefinition Width="6*" />

                                </Grid.ColumnDefinitions>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="18"
                                        FontWeight="Bold"
                                        Text="数据分析" />
                                    <Image
                                        Height="80"
                                        Margin="0,20,0,0"
                                        Source="/ProjectEye;component/Resources/product_manager.png" />
                                </StackPanel>
                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Text="Project Eye不仅会单独对工作时间、休息时间、跳过次数做出分析，还会结合您的设置以及一周的工作时间给您提供参考建议。"
                                    TextWrapping="WrapWithOverflow" />
                            </Grid>


                        </StackPanel>
                    </ScrollViewer>
                </Border>
                <ui:Project1UIButton
                    Grid.Row="1"
                    Width="160"
                    Height="35"
                    Command="{Binding CloseOnboardingCommand}"
                    Content="了 解"
                    FontSize="16" />
            </Grid>
        </ui:Project1UIModal>
    </ui:Project1UIWindow.ExtElement>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="9*" />
            <RowDefinition Height="auto" />

        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabItem Header="{DynamicResource Lang_Thisweek}">
                <Grid>
                    <Grid.RowDefinitions>
                        <!--<RowDefinition Height="50"/>-->
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <!--<TextBlock Text="本周数据分析" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>-->
                    <Grid Grid.Row="0">
                        <ScrollViewer>
                            <StackPanel>
                                <!--  工作  -->
                                <ui:ContentCard
                                    Margin="0"
                                    Padding="30"
                                    Background="#F2F2F9">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />

                                        </Grid.ColumnDefinitions>
                                        <Grid Width="350" HorizontalAlignment="Left">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="230" />
                                            </Grid.RowDefinitions>
                                            <!--  工作  -->
                                            <StackPanel Grid.Row="0" VerticalAlignment="Bottom">
                                                <StackPanel Margin="0,0,0,0" Orientation="Horizontal">
                                                    <Image
                                                        Width="32"
                                                        Height="32"
                                                        Source="/Resources/work.png" />

                                                    <!--<ui:Icon Unicode="&#xE977;" FontSize="24" VerticalAlignment="Center" Foreground="{DynamicResource ThemeBrush}"/>-->
                                                    <TextBlock
                                                        Margin="10,0,0,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="17"
                                                        FontWeight="Bold"
                                                        Foreground="{DynamicResource ThemeBrush}"
                                                        Text="{DynamicResource Lang_Work}" />
                                                </StackPanel>
                                                <Grid Margin="0,20,0,0">
                                                    <ui:CompareView
                                                        DataA="{Binding Data.LastWeekWork}"
                                                        DataB="{Binding Data.WeekWork}"
                                                        PopupText="{DynamicResource Lang_StatisticsWeekHoursTip}" />
                                                </Grid>
                                            </StackPanel>
                                            <chart:Chart
                                                Grid.Row="1"
                                                Margin="0,10,0,0"
                                                AverageDivisor="{Binding Data.WeekTrueWorkDays}"
                                                Background="Transparent"
                                                Data="{Binding Data.WeekWorkData}"
                                                IsAnimation="{Binding Data.IsAnimation}"
                                                ItemColor="{DynamicResource ThemeBrush}"
                                                TickLabelWidth="70"
                                                TickText="{DynamicResource Lang_StatisticsXhours}" />

                                        </Grid>
                                        <Grid
                                            Grid.Column="1"
                                            Margin="0,0,0,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">

                                            <StackPanel>
                                                <Image
                                                    MaxWidth="300"
                                                    HorizontalAlignment="Center"
                                                    Source="{Binding Data.WorktimeImageSource}" />
                                                <ContentControl>
                                                    <ContentControl.ContentTemplate>
                                                        <DataTemplate>
                                                            <Border
                                                                x:Name="WorkLevelBorder"
                                                                Width="auto"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                CornerRadius="5"
                                                                DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window, AncestorLevel=1}, Path=DataContext}">


                                                                <StackPanel
                                                                    Margin="10,5"
                                                                    VerticalAlignment="Center"
                                                                    Orientation="Horizontal">

                                                                    <ui:Icon
                                                                        x:Name="WorkLevelIcon"
                                                                        VerticalAlignment="Center"
                                                                        VerticalContentAlignment="Center"
                                                                        Foreground="{Binding ElementName=WeekWorkLevelText, Path=Foreground}"
                                                                        Unicode="&#xE74B;" />
                                                                    <TextBlock
                                                                        x:Name="WeekWorkLevelText"
                                                                        Margin="5,0,0,0"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        FontSize="14"
                                                                        Text="{Binding Data.WorkAnalysis}"
                                                                        TextWrapping="WrapWithOverflow" />
                                                                    <TextBlock
                                                                        x:Name="WeekWorkLevel"
                                                                        Text="{Binding Data.WeekWorkLevel}"
                                                                        Visibility="Collapsed" />
                                                                </StackPanel>

                                                            </Border>
                                                            <DataTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding ElementName=WeekWorkLevel, Path=Text}" Value="0">
                                                                    <Setter TargetName="WorkLevelBorder" Property="Background" Value="#7FE3E3E3" />
                                                                    <Setter TargetName="WeekWorkLevelText" Property="Foreground" Value="#FF686868" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ElementName=WeekWorkLevel, Path=Text}" Value="1">
                                                                    <Setter TargetName="WorkLevelBorder" Property="Background" Value="#7FFFD413" />
                                                                    <Setter TargetName="WeekWorkLevelText" Property="Foreground" Value="#FFB99800" />
                                                                    <Setter TargetName="WorkLevelIcon" Property="Unicode" Value="&#xE74A;" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ElementName=WeekWorkLevel, Path=Text}" Value="2">
                                                                    <Setter TargetName="WorkLevelBorder" Property="Background" Value="#7FFF2E00" />
                                                                    <Setter TargetName="WeekWorkLevelText" Property="Foreground" Value="#FF9C0000" />
                                                                    <Setter TargetName="WorkLevelIcon" Property="Unicode" Value="&#xE8C9;" />
                                                                </DataTrigger>
                                                            </DataTemplate.Triggers>
                                                        </DataTemplate>
                                                    </ContentControl.ContentTemplate>
                                                </ContentControl>
                                            </StackPanel>


                                        </Grid>
                                    </Grid>

                                </ui:ContentCard>
                                <!--  休息  -->
                                <ui:ContentCard
                                    Margin="0"
                                    Padding="30"
                                    Background="#F9FDFA">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />

                                        </Grid.ColumnDefinitions>
                                        <Grid Width="350" HorizontalAlignment="Left">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="230" />
                                            </Grid.RowDefinitions>
                                            <!--  休息  -->
                                            <StackPanel Grid.Row="0" VerticalAlignment="Bottom">
                                                <StackPanel Orientation="Horizontal">
                                                    <Image
                                                        Width="32"
                                                        Height="32"
                                                        Source="/Resources/rest.png" />
                                                    <!--<ui:Icon Unicode="&#xF2FA;" FontSize="24" VerticalAlignment="Center" Foreground="#82D29A"/>-->
                                                    <TextBlock
                                                        Margin="10,0,0,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="17"
                                                        FontWeight="Bold"
                                                        Foreground="#82D29A"
                                                        Text="{DynamicResource Lang_Break}" />
                                                </StackPanel>
                                                <Grid Margin="0,20,0,0">
                                                    <ui:CompareView
                                                        DataA="{Binding Data.LastWeekRest}"
                                                        DataB="{Binding Data.WeekRest}"
                                                        PopupText="{DynamicResource Lang_StatisticsWeekMinutesTip}" />
                                                </Grid>
                                            </StackPanel>
                                            <chart:Chart
                                                Grid.Row="1"
                                                AverageDivisor="{Binding Data.WeekTrueWorkDays}"
                                                Background="Transparent"
                                                Data="{Binding Data.WeekRestData}"
                                                IsAnimation="{Binding Data.IsAnimation}"
                                                ItemColor="#82D29A"
                                                TickLabelWidth="70"
                                                TickText="{DynamicResource Lang_StatisticsXminutes}" />

                                        </Grid>
                                        <Grid
                                            Grid.Column="1"
                                            Margin="0,0,0,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                            <StackPanel>
                                                <Image MaxWidth="300" Source="{Binding Data.ResttimeImageSource}" />
                                                <ContentControl>
                                                    <ContentControl.ContentTemplate>
                                                        <DataTemplate>
                                                            <Border
                                                                x:Name="RestLevelBorder"
                                                                Width="auto"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                CornerRadius="5"
                                                                DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window, AncestorLevel=1}, Path=DataContext}">


                                                                <StackPanel
                                                                    Margin="10,5"
                                                                    VerticalAlignment="Center"
                                                                    Orientation="Horizontal">

                                                                    <ui:Icon
                                                                        x:Name="RestLevelIcon"
                                                                        VerticalAlignment="Center"
                                                                        VerticalContentAlignment="Center"
                                                                        Foreground="{Binding ElementName=WeekRestLevelText, Path=Foreground}"
                                                                        Unicode="&#xE74B;" />
                                                                    <TextBlock
                                                                        x:Name="WeekRestLevelText"
                                                                        Margin="5,0,0,0"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        FontSize="14"
                                                                        Text="{Binding Data.RestAnalysis}"
                                                                        TextWrapping="WrapWithOverflow" />
                                                                    <TextBlock
                                                                        x:Name="WeekRestLevel"
                                                                        Text="{Binding Data.WeekRestLevel}"
                                                                        Visibility="Collapsed" />
                                                                </StackPanel>

                                                            </Border>
                                                            <DataTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding ElementName=WeekRestLevel, Path=Text}" Value="0">
                                                                    <Setter TargetName="RestLevelBorder" Property="Background" Value="#7FE3E3E3" />
                                                                    <Setter TargetName="WeekRestLevelText" Property="Foreground" Value="#FF686868" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ElementName=WeekRestLevel, Path=Text}" Value="1">
                                                                    <Setter TargetName="RestLevelBorder" Property="Background" Value="#7FFFD413" />
                                                                    <Setter TargetName="WeekRestLevelText" Property="Foreground" Value="#FFB99800" />
                                                                    <Setter TargetName="RestLevelIcon" Property="Unicode" Value="&#xE74A;" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ElementName=WeekRestLevel, Path=Text}" Value="2">
                                                                    <Setter TargetName="RestLevelBorder" Property="Background" Value="#7FFF2E00" />
                                                                    <Setter TargetName="WeekRestLevelText" Property="Foreground" Value="#FF9C0000" />
                                                                    <Setter TargetName="RestLevelIcon" Property="Unicode" Value="&#xE8C9;" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ElementName=WeekRestLevel, Path=Text}" Value="3">
                                                                    <Setter TargetName="RestLevelBorder" Property="Background" Value="#7F6FE455" />
                                                                    <Setter TargetName="WeekRestLevelText" Property="Foreground" Value="#FF167616" />
                                                                    <Setter TargetName="RestLevelIcon" Property="Unicode" Value="&#xE8C9;" />
                                                                </DataTrigger>
                                                            </DataTemplate.Triggers>
                                                        </DataTemplate>
                                                    </ContentControl.ContentTemplate>
                                                </ContentControl>

                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </ui:ContentCard>
                                <!--  跳过  -->
                                <ui:ContentCard
                                    Margin="0"
                                    Padding="30"
                                    Background="#ffe8e8">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />

                                        </Grid.ColumnDefinitions>

                                        <Grid Width="350" HorizontalAlignment="Left">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="230" />
                                            </Grid.RowDefinitions>
                                            <!--  跳过  -->
                                            <StackPanel Grid.Row="0" VerticalAlignment="Bottom">
                                                <StackPanel Orientation="Horizontal">
                                                    <Image
                                                        Width="32"
                                                        Height="32"
                                                        Source="/Resources/break.png" />

                                                    <!--<ui:Icon Unicode="&#xEE6E;" FontSize="24" VerticalAlignment="Center" Foreground="#F94520"/>-->
                                                    <TextBlock
                                                        Margin="10,0,0,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="17"
                                                        FontWeight="Bold"
                                                        Foreground="#F94520"
                                                        Text="{DynamicResource Lang_Skip}" />
                                                </StackPanel>
                                                <Grid Margin="0,20,0,0">
                                                    <ui:CompareView
                                                        DataA="{Binding Data.LastWeekSkip}"
                                                        DataB="{Binding Data.WeekSkip}"
                                                        PopupText="{DynamicResource Lang_StatisticsWeekXTip}" />
                                                </Grid>
                                            </StackPanel>
                                            <chart:Chart
                                                Grid.Row="1"
                                                AverageDivisor="{Binding Data.WeekTrueWorkDays}"
                                                Background="Transparent"
                                                Data="{Binding Data.WeekSkipData}"
                                                IsAnimation="{Binding Data.IsAnimation}"
                                                ItemColor="#F94520"
                                                TickLabelWidth="70"
                                                TickText="{DynamicResource Lang_StatisticsX}" />

                                        </Grid>
                                        <Grid
                                            Grid.Column="1"
                                            Margin="0,0,0,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                            <StackPanel>
                                                <Image MaxWidth="300" Source="{Binding Data.SkipImageSource}" />
                                                <ContentControl>
                                                    <ContentControl.ContentTemplate>
                                                        <DataTemplate>
                                                            <Border
                                                                x:Name="SkipLevelBorder"
                                                                Width="auto"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                CornerRadius="5"
                                                                DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window, AncestorLevel=1}, Path=DataContext}">


                                                                <StackPanel
                                                                    Margin="10,5"
                                                                    VerticalAlignment="Center"
                                                                    Orientation="Horizontal">

                                                                    <ui:Icon
                                                                        x:Name="SkipLevelIcon"
                                                                        VerticalAlignment="Center"
                                                                        VerticalContentAlignment="Center"
                                                                        Foreground="{Binding ElementName=WeekSkipLevelText, Path=Foreground}"
                                                                        Unicode="&#xE74B;" />
                                                                    <TextBlock
                                                                        x:Name="WeekSkipLevelText"
                                                                        Margin="5,0,0,0"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        FontSize="14"
                                                                        Text="{Binding Data.SkipAnalysis}"
                                                                        TextWrapping="WrapWithOverflow" />
                                                                    <TextBlock
                                                                        x:Name="WeekSkipLevel"
                                                                        Text="{Binding Data.WeekSkipLevel}"
                                                                        Visibility="Collapsed" />
                                                                </StackPanel>

                                                            </Border>
                                                            <DataTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding ElementName=WeekSkipLevel, Path=Text}" Value="0">
                                                                    <Setter TargetName="SkipLevelBorder" Property="Background" Value="#7FE3E3E3" />
                                                                    <Setter TargetName="WeekSkipLevelText" Property="Foreground" Value="#FF686868" />
                                                                </DataTrigger>

                                                                <DataTrigger Binding="{Binding ElementName=WeekSkipLevel, Path=Text}" Value="1">
                                                                    <Setter TargetName="SkipLevelBorder" Property="Background" Value="#7FFF2E00" />
                                                                    <Setter TargetName="WeekSkipLevelText" Property="Foreground" Value="#FF9C0000" />
                                                                    <Setter TargetName="SkipLevelIcon" Property="Unicode" Value="&#xE8C9;" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ElementName=WeekSkipLevel, Path=Text}" Value="2">
                                                                    <Setter TargetName="SkipLevelBorder" Property="Background" Value="#7F6FE455" />
                                                                    <Setter TargetName="WeekSkipLevelText" Property="Foreground" Value="#FF167616" />
                                                                    <Setter TargetName="SkipLevelIcon" Property="Unicode" Value="&#xE8E1;" />
                                                                </DataTrigger>
                                                            </DataTemplate.Triggers>
                                                        </DataTemplate>
                                                    </ContentControl.ContentTemplate>
                                                </ContentControl>
                                            </StackPanel>

                                        </Grid>
                                    </Grid>

                                </ui:ContentCard>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>

            </TabItem>
            <TabItem Header="{DynamicResource Lang_Monthlyview}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="25*" />
                        <ColumnDefinition Width="741*" />
                    </Grid.ColumnDefinitions>
                    <!--<Grid.Background>
                        <ImageBrush ImageSource="/ProjectEye;component/Resources/conference_presentation__monochromatic.png" Stretch="Uniform" Opacity=".02"/>
                    </Grid.Background>-->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid
                        Grid.Row="0"
                        Grid.ColumnSpan="2"
                        Margin="0,7"
                        VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <!--<TextBlock Text="{DynamicResource Lang_Monthly}" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>-->
                        <date:DatePicker
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            SelectedMonth="{Binding Data.Month, Mode=TwoWay}"
                            SelectedYear="{Binding Data.Year, Mode=TwoWay}" />
                        <ui:Project1UIButton
                            Grid.Column="1"
                            Width="auto"
                            Height="auto"
                            Margin="0,0,10,0"
                            Padding="10,6"
                            HorizontalAlignment="Right"
                            Command="{Binding exportDataCommand}"
                            Content="{DynamicResource Lang_ExportMonthData}"
                            Icon="Export"
                            Style="{DynamicResource basic}" />
                    </Grid>
                    <ScrollViewer Grid.Row="1" Grid.ColumnSpan="2">
                        <Grid Margin="18">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="90" />
                                <RowDefinition Height="350" />
                                <RowDefinition Height="90" />
                                <RowDefinition Height="350" />
                                <RowDefinition Height="90" />
                                <RowDefinition Height="350" />
                                <RowDefinition Height="90" />
                                <RowDefinition Height="350" />
                            </Grid.RowDefinitions>
                            <!--  工作  -->
                            <StackPanel Grid.Row="0" VerticalAlignment="Bottom">
                                <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                    <Image
                                        Width="32"
                                        Height="32"
                                        Source="/Resources/work.png" />

                                    <!--<ui:Icon Unicode="&#xE977;" FontSize="24" VerticalAlignment="Center" Foreground="{DynamicResource ThemeBrush}"/>-->
                                    <TextBlock
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="17"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource ThemeBrush}"
                                        Text="{DynamicResource Lang_Work}" />
                                </StackPanel>
                                <Grid Margin="0,10,0,0">
                                    <ui:CompareView
                                        DataA="{Binding Data.LastMonthWork}"
                                        DataB="{Binding Data.MonthWork}"
                                        PopupText="{DynamicResource Lang_StatisticsMonthlyHoursTip}" />
                                </Grid>
                            </StackPanel>
                            <chart:Chart
                                Grid.Row="1"
                                Margin="0,10,0,0"
                                Background="Transparent"
                                Data="{Binding Data.MonthWorkData}"
                                IsAnimation="{Binding Data.IsAnimation}"
                                ItemColor="{DynamicResource ThemeBrush}"
                                TickLabelWidth="70"
                                TickText="{DynamicResource Lang_StatisticsXhours}">
                                <chart:Chart.ContextMenu>
                                    <ContextMenu StaysOpen="true">
                                        <MenuItem Command="{Binding GenerateMonthlyDataImgCommand}" Header="生成图片" />
                                    </ContextMenu>
                                </chart:Chart.ContextMenu>
                            </chart:Chart>

                            <!--  休息  -->
                            <StackPanel Grid.Row="2" VerticalAlignment="Bottom">
                                <StackPanel Orientation="Horizontal">
                                    <Image
                                        Width="32"
                                        Height="32"
                                        Source="/Resources/rest.png" />

                                    <!--<ui:Icon Unicode="&#xF2FA;" FontSize="24" VerticalAlignment="Center" Foreground="#1CE072"/>-->
                                    <TextBlock
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="17"
                                        FontWeight="Bold"
                                        Foreground="#1CE072"
                                        Text="{DynamicResource Lang_Break}" />
                                </StackPanel>
                                <Grid Margin="0,10,0,0">
                                    <ui:CompareView
                                        DataA="{Binding Data.LastMonthRest}"
                                        DataB="{Binding Data.MonthRest}"
                                        PopupText="{DynamicResource Lang_StatisticsMonthlyMinutesTip}" />
                                </Grid>
                            </StackPanel>
                            <chart:Chart
                                Grid.Row="3"
                                Background="Transparent"
                                Data="{Binding Data.MonthRestData}"
                                IsAnimation="{Binding Data.IsAnimation}"
                                ItemColor="#1CE072"
                                TickLabelWidth="70"
                                TickText="{DynamicResource Lang_StatisticsXminutes}" />
                            <!--  跳过  -->
                            <StackPanel Grid.Row="4" VerticalAlignment="Bottom">
                                <StackPanel Orientation="Horizontal">
                                    <Image
                                        Width="32"
                                        Height="32"
                                        Source="/Resources/break.png" />

                                    <!--<ui:Icon Unicode="&#xEE6E;" FontSize="24" VerticalAlignment="Center" Foreground="#F94520"/>-->
                                    <TextBlock
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="17"
                                        FontWeight="Bold"
                                        Foreground="#F94520"
                                        Text="{DynamicResource Lang_Skip}" />
                                </StackPanel>
                                <Grid Margin="0,10,0,0">
                                    <ui:CompareView
                                        DataA="{Binding Data.LastMonthSkip}"
                                        DataB="{Binding Data.MonthSkip}"
                                        PopupText="{DynamicResource Lang_StatisticsMonthlyXTip}" />
                                </Grid>
                            </StackPanel>
                            <chart:Chart
                                Grid.Row="5"
                                Background="Transparent"
                                Data="{Binding Data.MonthSkipData}"
                                IsAnimation="{Binding Data.IsAnimation}"
                                ItemColor="#F94520"
                                TickLabelWidth="70"
                                TickText="{DynamicResource Lang_StatisticsX}" />

                            <!--  番茄  -->
                            <StackPanel Grid.Row="6" VerticalAlignment="Bottom">
                                <StackPanel Orientation="Horizontal">
                                    <Image
                                        Width="32"
                                        </Grid>
                                    </Grid>
                                </Border>

                                <TextBlock
                                    Margin="0,20,0,0"
                                    Text="{DynamicResource Lang_Tomatodescription2}"
                                    TextWrapping="Wrap" />
                                <Button
                                    HorizontalAlignment="Left"
                                    Command="{Binding openURLCommand}"
                                    CommandParameter="https://zh.wikipedia.org/wiki/%E7%95%AA%E8%8C%84%E5%B7%A5%E4%BD%9C%E6%B3%95"
                                    Style="{DynamicResource CustomButton}">

                                    <StackPanel
                                        Margin="0,0,0,0"
                                        Cursor="Hand"
                                        Orientation="Horizontal">
                                        <ui:Icon Foreground="#4f6bed" Unicode="&#xE72A;" />
                                        <TextBlock
                                            Padding="10"
                                            Foreground="#4f6bed"
                                            Text="{DynamicResource Lang_Learnmore}" />
                                    </StackPanel>

                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>

            </TabItem>
        </TabControl>
    </Grid>
</ui:Project1UIWindow>
