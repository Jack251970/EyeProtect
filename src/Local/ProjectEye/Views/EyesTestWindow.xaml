<ui:Project1UIWindow
    x:Class="ProjectEye.Views.EyesTestWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ProjectEye.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="clr-namespace:Project1.UI.Controls;assembly=Project1.UI"
    Title="视力测试Beta"
    Width="900"
    Height="550"
    mc:Ignorable="d">
    <ui:Project1UIWindow.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FontBrush}" />
        </Style>
    </ui:Project1UIWindow.Resources>
    <Grid>
        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="测试">
                <Grid>
                    <Grid Margin="20" Visibility="{Binding ScoreVisibility}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock
                                Margin="10"
                                FontSize="16"
                                FontWeight="Bold"
                                TextWrapping="Wrap">
                                测试已完成，本次分数：<Run Text="{Binding Score}" />
                                /6</TextBlock>
                            <TextBlock
                                Margin="10"
                                Text="{Binding ScoreInfo}"
                                TextWrapping="Wrap" />
                            <ui:Project1UIButton
                                MinWidth="120"
                                MinHeight="40"
                                Margin="10"
                                Command="{Binding EndCommand}"
                                Content="结束" />
                        </StackPanel>
                    </Grid>
                    <Grid Margin="20" Visibility="{Binding InfoVisibility}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock
                                Margin="10"
                                FontSize="14"
                                FontWeight="Bold"
                                TextWrapping="Wrap">
                                请了解：Project Eye的视力测试并不是近/远视力的标准测试，而是非常简单的近视力测试！因受屏幕分辨率影响每台显示器的测试结果均可能不同。测试结果仅作为参考！
                            </TextBlock>
                            <TextBlock
                                Margin="10"
                                FontSize="14"
                                FontWeight="Bold"
                                TextWrapping="Wrap">
                                开始测试前的准备：请将眼睛与屏幕的距离保持在70-80厘米，如果你没有测量工具，可以使用手肘到手腕两倍的距离。
                            </TextBlock>
                            <ui:Project1UIButton
                                MinWidth="120"
                                MinHeight="40"
                                Margin="10"
                                Command="{Binding ShowTestCommand}"
                                Content="我准备好了" />
                        </StackPanel>
                    </Grid>
                    <Grid Visibility="{Binding TestVisibility}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="7*" />
                            <RowDefinition Height="3*" />

                        </Grid.RowDefinitions>

                        <Grid
                            Grid.Row="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <TextBlock FontSize="{Binding FontSize}">PROJECT EYE</TextBlock>

                        </Grid>
                        <StackPanel Grid.Row="1" HorizontalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="16"
                                FontWeight="Bold">
                                是否能识别屏幕中间的文字？
                            </TextBlock>
                            <StackPanel Margin="20" Orientation="Horizontal">
                                <ui:Project1UIButton
                                    MinWidth="120"
                                    MinHeight="40"
                                    Margin="10"
                                    Command="{Binding TestCommand}"
                                    CommandParameter="0"
                                    Content="能" />
                                <ui:Project1UIButton
                                    MinWidth="120"
                                    MinHeight="40"
                                    Margin="10"
                                    Command="{Binding TestCommand}"
                                    CommandParameter="1"
                                    Content="不能"
                                    Style="{DynamicResource basic}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="以往的数据">
                <ui:Project1UIChart
                    Margin="10"
                    Data="{Binding Mode=TwoWay, Path=EyesData}"
                    Label="分"
                    Labels="{Binding Mode=TwoWay, Path=Labels}"
                    MaxData="6" />
            </TabItem>
        </TabControl>

    </Grid>
</ui:Project1UIWindow>
