<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Project1.UI.Controls">




    <Style TargetType="{x:Type controls:Project1UIDesignItem}">
        <Setter Property="Background" Value="#0C6495ED" />
        <Setter Property="SnapsToDevicePixels" Value="False" />
        <Setter Property="Width" Value="{Binding Width, Mode=TwoWay}" />
        <Setter Property="Height" Value="{Binding Height, Mode=TwoWay}" />
        <!--<Setter Property="BorderThickness" Value="{DynamicResource InputThickness}"/>-->
        <!--<Setter Property="Foreground" Value="{DynamicResource InputForeground}"/>-->
        <!--<Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>-->
        <Setter Property="InputMethod.IsInputMethodEnabled" Value="False" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:Project1UIDesignItem}">
                    <Grid x:Name="Container" Background="{TemplateBinding Background}">

                        <!--<Border
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,-30,0,0"
                            Height="30"
                            Width="100"
                            Background="#6495ED">
                            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Text="{TemplateBinding ControlType}" Foreground="White"/>
                        </Border>-->
                        <Popup
                            x:Name="popup"
                            Width="259"
                            Height="auto"
                            MaxHeight="281"
                            AllowsTransparency="True"
                            Placement="MousePoint">
                            <Border
                                Margin="5"
                                Background="White"
                                BorderBrush="#ccc"
                                BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="5"
                                        Opacity="0.3"
                                        ShadowDepth="0" />
                                </Border.Effect>
                                <Grid Margin="10,5,10,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontWeight="Bold"
                                        Text="{DynamicResource Lang_Attribute}" />
                                    <ScrollViewer x:Name="ScrollViewer" Grid.Row="1">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="*" />

                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="*" />

                                                </Grid.RowDefinitions>
                                                <TextBlock VerticalAlignment="Center" Text="{DynamicResource Lang_Type}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    Text="{TemplateBinding ItemTypeName}" />
                                                <!--  尺寸宽高  -->
                                                <TextBlock
                                                    Grid.Row="1"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Center"
                                                    Text="{DynamicResource Lang_Width}" />
                                                <controls:Project1UIInput
                                                    Grid.Row="1"
                                                    Grid.Column="1"
                                                    Width="auto"
                                                    Height="25"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Top"
                                                    Minimum="1"
                                                    SmallChange="1"
                                                    Text="{Binding Width, Mode=TwoWay}"
                                                    Type="Number" />
                                                <TextBlock
                                                    Grid.Row="2"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Center"
                                                    Text="{DynamicResource Lang_Height}" />
                                                <controls:Project1UIInput
                                                    Grid.Row="2"
                                                    Grid.Column="1"
                                                    Width="auto"
                                                    Height="25"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Top"
                                                    Minimum="1"
                                                    SmallChange="1"
                                                    Text="{Binding Height, Mode=TwoWay}"
                                                    Type="Number" />
                                                <!--  背景色  -->
                                                <TextBlock
                                                    Grid.Row="3"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Center"
                                                    Text="{DynamicResource Lang_BackgroundColor}"
                                                    Visibility="{TemplateBinding ColorVisibility}" />
                                                <controls:Project1UIColorSelect
                                                    Grid.Row="3"
                                                    Grid.Column="1"
                                                    Width="20"
                                                    Height="20"
                                                    Margin="0,10,0,0"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    Visibility="{TemplateBinding ColorVisibility}"
                                                    Color="{Binding Background, Mode=TwoWay}" />
                                                <!--  边框色  -->
                                                <TextBlock
                                                    Grid.Row="4"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Center"
                                                    Text="边宽颜色"
                                                    Visibility="{TemplateBinding ColorVisibility}" />
                                                <controls:Project1UIColorSelect
                                                    Grid.Row="4"
                                                    Grid.Column="1"
                                                    Width="20"
                                                    Height="20"
                                                    Margin="0,10,0,0"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    Visibility="{TemplateBinding ColorVisibility}"
                                                    Color="{Binding BorderColor, Mode=TwoWay}" />
                                                <!--  文字  -->
                                                <TextBlock
                                                    Grid.Row="5"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Top"
                                                    Text="{DynamicResource Lang_Content}"
                                                    Visibility="{TemplateBinding TextInputVisibility}" />
                                                <controls:Project1UIInput
                                                    Grid.Row="5"
                                                    Grid.Column="1"
                                                    Width="auto"
                                                    Height="40"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Top"
                                                    AcceptsReturn="True"
                                                    Text="{Binding Text, Mode=TwoWay}"
                                                    TextWrapping="Wrap"
                                                    Visibility="{TemplateBinding TextInputVisibility}" />
                                                <!--  透明度  -->
                                                <TextBlock
                                                    Grid.Row="6"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Top"
                                                    Text="{DynamicResource Lang_Opacity}" />
                                                <controls:Project1UIInput
                                                    Grid.Row="6"
                                                    Grid.Column="1"
                                                    Width="auto"
                                                    Height="25"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Top"
                                                    Maximum="1"
                                                    Minimum="0"
                                                    Text="{Binding Opacity, Mode=TwoWay}"
                                                    Type="Number" />
                                                <!--  图片选择  -->
                                                <TextBlock
                                                    Grid.Row="7"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Top"
                                                    Text="{DynamicResource Lang_Image}"
                                                    Visibility="{TemplateBinding ImageInputVisibility}" />
                                                <controls:Project1UIInput
                                                    x:Name="a123"
                                                    Grid.Row="7"
                                                    Grid.Column="1"
                                                    Width="auto"
                                                    Height="25"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Top"
                                                    ExtNames="jpg|*.jpg|png|*.png|gif|*.gif"
                                                    IsDisabledInput="True"
                                                    Placeholder="{Binding Image, Mode=TwoWay}"
                                                    Type="FileSelect"
                                                    Visibility="{TemplateBinding ImageInputVisibility}" />
                                                <!--  按钮类型属性  -->
                                                <TextBlock
                                                    Grid.Row="8"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Top"
                                                    Text="{DynamicResource Lang_Content}"
                                                    Visibility="{TemplateBinding ButtonVisibility}" />
                                                <controls:Project1UIInput
                                                    Grid.Row="8"
                                                    Grid.Column="1"
                                                    Width="auto"
                                                    Height="25"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Top"
                                                    Text="{Binding ButtonText, Mode=TwoWay}"
                                                    Visibility="{TemplateBinding ButtonVisibility}" />
                                                <!--  文字大小  -->
                                                <TextBlock
                                                    Grid.Row="9"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Top"
                                                    Text="{DynamicResource Lang_FontSize}"
                                                    Visibility="{TemplateBinding FontSizeVisibility}" />
                                                <controls:Project1UIInput
                                                    Grid.Row="9"
                                                    Grid.Column="1"
                                                    Width="auto"
                                                    Height="25"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Top"
                                                    Minimum="1"
                                                    SmallChange="1"
                                                    Text="{Binding FontSize, Mode=TwoWay}"
                                                    Type="Number"
                                                    Visibility="{TemplateBinding FontSizeVisibility}" />
                                                <!--  文字色  -->
                                                <TextBlock
                                                    Grid.Row="10"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Center"
                                                    Text="{DynamicResource Lang_FontColor}"
                                                    Visibility="{TemplateBinding TextColorVisibility}" />
                                                <controls:Project1UIColorSelect
                                                    Grid.Row="10"
                                                    Grid.Column="1"
                                                    Width="20"
                                                    Height="20"
                                                    Margin="0,10,0,0"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    Visibility="{TemplateBinding TextColorVisibility}"
                                                    Color="{Binding TextColor, Mode=TwoWay}" />
                                                <!--  文字加粗  -->
                                                <TextBlock
                                                    Grid.Row="11"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Center"
                                                    Text="{DynamicResource Lang_FontBold}"
                                                    Visibility="{TemplateBinding FontSizeVisibility}" />
                                                <CheckBox
                                                    Grid.Row="11"
                                                    Grid.Column="1"
                                                    Width="20"
                                                    Height="20"
                                                    Margin="0,10,0,0"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    IsChecked="{Binding IsFontBold, Mode=TwoWay}"
                                                    Visibility="{TemplateBinding FontSizeVisibility}" />
                                                <TextBlock
                                                    Grid.Row="12"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Top"
                                                    Text="{DynamicResource Lang_Style}"
                                                    Visibility="{TemplateBinding ButtonVisibility}" />
                                                <controls:Project1UIInput
                                                    Grid.Row="12"
                                                    Grid.Column="1"
                                                    Width="auto"
                                                    Height="25"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Top"
                                                    Text="{Binding ButtonStyleName, Mode=TwoWay}"
                                                    Visibility="{TemplateBinding ButtonVisibility}" />
                                                <!--  按钮命令  -->
                                                <TextBlock
                                                    Grid.Row="13"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Top"
                                                    Text="{DynamicResource Lang_Command}"
                                                    Visibility="{TemplateBinding ButtonVisibility}" />
                                                <controls:Project1UIInput
                                                    Grid.Row="13"
                                                    Grid.Column="1"
                                                    Width="auto"
                                                    Height="25"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Top"
                                                    Text="{Binding Command, Mode=TwoWay}"
                                                    Visibility="{TemplateBinding ButtonVisibility}" />
                                                <!--  文字对齐  -->
                                                <TextBlock
                                                    Grid.Row="14"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Center"
                                                    Text="{DynamicResource Lang_Alignment}"
                                                    Visibility="{TemplateBinding TextColorVisibility}" />
                                                <ComboBox
                                                    Grid.Row="14"
                                                    Grid.Column="1"
                                                    Width="auto"
                                                    Height="25"
                                                    Margin="0,10,0,0"
                                                    VerticalAlignment="Center"
                                                    DisplayMemberPath="DisplayName"
                                                    ItemsSource="{Binding TextAlignmentList}"
                                                    SelectedItem="{Binding TextAlignment}"
                                                    SelectedValue="{Binding TextAlignment.Value}"
                                                    SelectedValuePath="Value"
                                                    Visibility="{TemplateBinding TextColorVisibility}" />
                                            </Grid>


                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Popup>
                        <Border
                            x:Name="Border"
                            BorderBrush="Transparent"
                            BorderThickness="1">
                            <ContentPresenter
                                Margin="-1"
                                RecognizesAccessKey="True"
                                SnapsToDevicePixels="False" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Border" Property="BorderBrush" Value="#6495ED" />
                        </MultiTrigger>


                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>

    </Style>


</ResourceDictionary>