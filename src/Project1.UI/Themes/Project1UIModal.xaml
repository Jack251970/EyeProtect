<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Project1.UI.Controls">
    <Style TargetType="{x:Type controls:Project1UIModal}">
        <Setter Property="Background" Value="White" />
        <Setter Property="Foreground" Value="#323130" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:Project1UIModal}">
                    <ControlTemplate.Resources>
                        <Storyboard x:Key="ShowAnimation">
                            <DoubleAnimation
                                Storyboard.TargetProperty="MaskLayerOpacity"
                                To=".4"
                                Duration="0:0:.2" />
                        </Storyboard>
                        <Storyboard x:Key="CloseAnimation">
                            <DoubleAnimation
                                Storyboard.TargetProperty="MaskLayerOpacity"
                                To="0"
                                Duration="0:0:.2" />
                        </Storyboard>

                    </ControlTemplate.Resources>
                    <Grid>
                        <!--  内容  -->
                        <!--<Border
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Background="{TemplateBinding Background}"
                            CornerRadius="2"
                            Panel.ZIndex="2"
                            Padding="10,15"
                            Margin="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            >
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="5" Opacity="0.3"  ShadowDepth="0"/>
                            </Border.Effect>-->
                        <!--<TextBlock
                                TextWrapping="WrapWithOverflow"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Foreground="{TemplateBinding Foreground}"
                                Text="{TemplateBinding Text}"
                                />-->
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Panel.ZIndex="2" />
                        <!--</Border>-->
                        <Border
                            x:Name="MaskLayer"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Panel.ZIndex="1"
                            Background="Black"
                            Opacity="{TemplateBinding MaskLayerOpacity}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Show" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard Storyboard="{StaticResource ShowAnimation}" />
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard Storyboard="{StaticResource CloseAnimation}" />
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

    </Style>


</ResourceDictionary>