<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cmd="clr-namespace:Project1.UI.Controls.Commands"
    xmlns:controls="clr-namespace:Project1.UI.Controls"
    xmlns:s="clr-namespace:System;assembly=mscorlib">

    <Style TargetType="{x:Type controls:Project1UIWindow}">
        <Setter Property="BorderThickness" Value="{DynamicResource WindowBorderThickness}" />
        <Setter Property="BorderBrush" Value="{DynamicResource WindowBorderBrush}" />
        <Setter Property="Background" Value="{DynamicResource WindowBackground}" />
        <!--<Setter Property="Logo" Value="{DynamicResource WindowLogo}" />-->
        <Setter Property="Foreground" Value="{DynamicResource FontBrush}" />

        <Setter Property="ResizeMode" Value="CanResizeWithGrip" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="WindowChrome.WindowChrome">
            <Setter.Value>
                <WindowChrome
                    CaptionHeight="{DynamicResource WindowTitleBarHeight}"
                    CornerRadius="0"
                    GlassFrameThickness="1"
                    NonClientFrameEdges="None"
                    UseAeroCaptionButtons="False" />
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:Project1UIWindow}">
                    <!--<ControlTemplate.Resources>
                    -->
                    <!--<DoubleAnimation x:Key="test"
                                         To="{Binding ElementName=NavigationView,Path=Width}"/>-->
                    <!--

                        <Storyboard x:Key="Storyboardload">
                            <DoubleAnimation Storyboard.TargetName="WindowBorder" Storyboard.TargetProperty="Opacity" Duration="00:00:0.1" From="0" To="1" >
                            </DoubleAnimation>
                        </Storyboard>
                    -->
                    <!--<Storyboard x:Key="OpenNavigationViewAnimation"
                                   >
                            <DoubleAnimation Storyboard.TargetName="NavigationViewGrid" Storyboard.TargetProperty="Width"
                                             To="{Binding ElementName=NavigationViewGrid,Path=Width}"  Duration="0:0:.2" />




                        </Storyboard>
                        <Storyboard x:Key="CloseNavigationViewAnimation">
                            <DoubleAnimation Storyboard.TargetName="NavigationViewGrid" Storyboard.TargetProperty="Width" To="0"  Duration="0:0:.2" />

                        </Storyboard>-->
                    <!--
                    </ControlTemplate.Resources>-->
                    <Border x:Name="WindowBorder" Margin="{Binding Source={x:Static SystemParameters.WindowNonClientFrameThickness}}">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <AdornerDecorator>
                                <Grid>
                                    <!--  拓展内容  -->
                                    <ContentControl
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Content="{TemplateBinding ExtElement}" />
                                    <Grid x:Name="WindowContent">

                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />

                                        </Grid.RowDefinitions>

                                        <!--  标题栏  -->
                                        <Grid Height="{DynamicResource WindowTitleBarHeight}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />

                                                <ColumnDefinition Width="*" />

                                            </Grid.ColumnDefinitions>
                                            <Grid
                                                Grid.Column="0"
                                                ToolTip="{TemplateBinding Title}"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
                                                <!--  LOGO区域  -->

                                                <Button
                                                    Width="35"
                                                    Margin="20,0"
                                                    Command="{x:Static cmd:Project1UIWindowCommands.LogoButtonClickCommand}"
                                                    Style="{DynamicResource WindowSystemLogoButton}">
                                                    <ContentControl
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Content="{TemplateBinding Logo}" />
                                                </Button>
                                                <!--<Border Margin="20,0" Background="{DynamicResource WindowBorderBrush}" Width="35">

                                                <ContentControl VerticalAlignment="Center" HorizontalAlignment="Center" Content="{TemplateBinding Logo}" />

                                            </Border>-->
                                            </Grid>
                                            <!--  导航栏区域  -->
                                            <Grid
                                                x:Name="NavigationViewGrid"
                                                Grid.Column="1"
                                                Panel.ZIndex="3"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
                                                <ContentControl
                                                    x:Name="NavigationView"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Content="{TemplateBinding NavigationView}" />
                                            </Grid>
                                            <Grid Grid.Column="2" Panel.ZIndex="3">
                                                <!--  标题区域  -->
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontWeight="Bold"
                                                    Text="{TemplateBinding Title}" />

                                            </Grid>
                                            <Grid
                                                Grid.Column="3"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Panel.ZIndex="3"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
                                                <!--  系统按钮区域  -->

                                                <StackPanel Orientation="Horizontal">
                                                    <!--  最小化  -->
                                                    <Button
                                                        Width="34"
                                                        Height="26"
                                                        Command="{x:Static cmd:Project1UIWindowCommands.MinimizeWindowCommand}"
                                                        Content="&#xE921;"
                                                        Style="{DynamicResource WindowSystemButton}"
                                                        ToolTip="最小化" />
                                                    <!--  最大化  -->
                                                    <Button
                                                        x:Name="MaximizeButton"
                                                        Width="34"
                                                        Height="26"
                                                        Command="{x:Static cmd:Project1UIWindowCommands.MaximizeWindowCommand}"
                                                        Content="&#xE922;"
                                                        Style="{DynamicResource WindowSystemButton}"
                                                        ToolTip="最大化" />
                                                    <!--  还原  -->
                                                    <Button
                                                        x:Name="RestoreButton"
                                                        Width="34"
                                                        Height="26"
                                                        Command="{x:Static cmd:Project1UIWindowCommands.RestoreWindowCommand}"
                                                        Content="&#xE923;"
                                                        Style="{DynamicResource WindowSystemButton}"
                                                        ToolTip="向下还原"
                                                        Visibility="Collapsed" />
                                                    <!--  关闭  -->
                                                    <Button
                                                        Width="34"
                                                        Height="26"
                                                        Command="{x:Static cmd:Project1UIWindowCommands.CloseWindowCommand}"
                                                        Content="&#xE8BB;"
                                                        Style="{DynamicResource WindowSystemButton}"
                                                        ToolTip="关闭" />

                                                </StackPanel>


                                            </Grid>
                                        </Grid>



                                        <!--  窗体内容  -->
                                        <ContentPresenter Grid.Row="1" Panel.ZIndex="2" />

                                    </Grid>
                                </Grid>

                            </AdornerDecorator>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="WindowState" Value="Maximized">
                            <!--  最大化时调整外边距，否则显示不完整  -->
                            <Setter TargetName="WindowContent" Property="Margin" Value="7" />
                            <Setter TargetName="MaximizeButton" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="RestoreButton" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <Trigger Property="WindowState" Value="Normal">
                            <Setter TargetName="MaximizeButton" Property="Visibility" Value="Visible" />
                            <Setter TargetName="RestoreButton" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <!--<EventTrigger RoutedEvent="Window.Loaded">
                        -->
                        <!--  窗口载入动画  -->
                        <!--
                            <BeginStoryboard Storyboard="{StaticResource Storyboardload}">
                            </BeginStoryboard>

                        </EventTrigger>-->
                        <!--<Trigger Property="IsOpenNavigationView" Value="False">
                            <Setter TargetName="NavigationViewGrid" Property="Width" Value="0" />
                        </Trigger>-->

                        <!--<Trigger Property="IsOpenNavigationView" Value="False">
                            <Setter TargetName="NavigationViewGrid" Property="Width" Value="{Binding ElementName=NavigationView,Path=Width}" />
                            <Trigger.EnterActions>
                                <BeginStoryboard Storyboard="{StaticResource OpenNavigationViewAnimation}">
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard Storyboard="{StaticResource CloseNavigationViewAnimation}">
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>-->
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

    </Style>


</ResourceDictionary>