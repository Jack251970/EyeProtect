<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Project1.UI.Controls.ChartControl;assembly=Project1.UI">
    <Style x:Key="ScrollButton" TargetType="Button">
        <Setter Property="Height" Value="40" />
        <Setter Property="Width" Value="40" />
        <Setter Property="Cursor" Value="Hand" />

        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}"
                        Background="{DynamicResource BasicButtonBackground}"
                        CornerRadius="40">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="5"
                                Opacity="0.2"
                                ShadowDepth="1" />
                        </Border.Effect>
                        <TextBlock
                            x:Name="icon"
                            Width="14"
                            Height="14"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="/Project1.UI;component/Assets/IconFonts/#Fabric External MDL2 Assets"
                            FontSize="14"
                            Foreground="#9e9ea7"
                            Text="{TemplateBinding ContentStringFormat}"
                            TextAlignment="Center">
                            <TextBlock.RenderTransform>
                                <ScaleTransform CenterX="7" CenterY="7" ScaleX="1" ScaleY="1" />
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualStateGroup.Transitions>
                                    <VisualTransition GeneratedDuration="0:0:0.2" />
                                    <VisualTransition GeneratedDuration="0" To="Pressed" />
                                </VisualStateGroup.Transitions>
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="MouseOver">
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="icon" Storyboard.TargetProperty="(TextBlock.RenderTransform).(ScaleTransform.ScaleX)">
                                            <EasingDoubleKeyFrame KeyTime="0" Value="1.3" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="icon" Storyboard.TargetProperty="(TextBlock.RenderTransform).(ScaleTransform.ScaleY)">
                                            <EasingDoubleKeyFrame KeyTime="0" Value="1.3" />
                                        </DoubleAnimationUsingKeyFrames>

                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="icon" Storyboard.TargetProperty="(TextBlock.RenderTransform).(ScaleTransform.ScaleX)">
                                            <EasingDoubleKeyFrame KeyTime="0" Value=".8" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="icon" Storyboard.TargetProperty="(TextBlock.RenderTransform).(ScaleTransform.ScaleY)">
                                            <EasingDoubleKeyFrame KeyTime="0" Value=".8" />
                                        </DoubleAnimationUsingKeyFrames>

                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:Chart}">
        <Setter Property="Background" Value="White" />
        <Setter Property="Foreground" Value="{DynamicResource FontBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:Chart}">
                    <!--<ControlTemplate.Resources>
                        <Storyboard x:Key="ShowAnimation">
                            <DoubleAnimation Storyboard.TargetProperty="MaskLayerOpacity"
                                             To=".4"  Duration="0:0:.2" />
                        </Storyboard>
                        <Storyboard x:Key="CloseAnimation">
                            <DoubleAnimation Storyboard.TargetProperty="MaskLayerOpacity" To="0"  Duration="0:0:.2" />
                        </Storyboard>

                    </ControlTemplate.Resources>-->
                    <Border
                        Margin="{TemplateBinding Margin}"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid x:Name="MainContainer">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid Width="{TemplateBinding TickLabelWidth}" Margin="0,0,10,0">
                                <!--  最大值标注  -->
                                <Border
                                    x:Name="MaxValueBorder"
                                    Height="50"
                                    Margin="0,-5,0,0"
                                    VerticalAlignment="Top">
                                    <TextBlock
                                        x:Name="MaxValueLabel"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Foreground="#9e9ea7" />
                                </Border>
                                <!--  平均值标注  -->
                                <Border
                                    x:Name="AverageBorder"
                                    Height="50"
                                    VerticalAlignment="Bottom"
                                    Panel.ZIndex="3"
                                    Visibility="{TemplateBinding AverageVisibility}">
                                    <TextBlock
                                        x:Name="AverageLabel"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Foreground="#82D29A"
                                        Text="{TemplateBinding AverageText}">
                                        <!--<TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource TickTextConverter}">
                                            <Binding Path="Average" RelativeSource="{RelativeSource Self}"/>
                                        </MultiBinding>
                                    </TextBlock.Text>-->
                                    </TextBlock>
                                </Border>
                                <!--  底部值标注  -->
                                <Border
                                    x:Name="BottomValueBorder"
                                    Height="50"
                                    VerticalAlignment="Bottom">
                                    <TextBlock
                                        x:Name="BottomValueLabel"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Foreground="#9e9ea7" />
                                </Border>
                            </Grid>
                            <!--  主要内容视图  -->
                            <Grid Grid.Column="1">
                                <!--  最大值刻度  -->
                                <Rectangle
                                    x:Name="MaxTick"
                                    Height="2"
                                    Margin="0,20,0,0"
                                    VerticalAlignment="Top"
                                    Panel.ZIndex="1"
                                    Fill="#f3f2f1" />
                                <!--  平均值刻度  -->
                                <Popup
                                    x:Name="Popup"
                                    AllowsTransparency="True"
                                    HorizontalOffset="-10"
                                    Placement="Top"
                                    PlacementTarget="{Binding ElementName=AverageTick}"
                                    VerticalOffset="-10">
                                    <Border
                                        x:Name="PopupBorder"
                                        Margin="15"
                                        Padding="10"
                                        Background="{DynamicResource WindowBackground}"
                                        BorderBrush="{DynamicResource WindowBorderBrush}"
                                        BorderThickness="1">
                                        <Border.Effect>
                                            <DropShadowEffect
                                                BlurRadius="5"
                                                Opacity="0.2"
                                                ShadowDepth="1" />
                                        </Border.Effect>
                                        <Grid>
                                            <TextBlock>
                                                <Run Text="{DynamicResource Lang_Average}" />
                                                <Run Text="{TemplateBinding AverageText}" />
                                            </TextBlock>
                                            <Path
                                                Width="15"
                                                Height="15"
                                                Margin="-5,0,0,-25"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Bottom"
                                                Data="M 0 0 L 7.5 7.5 L 15 0"
                                                Fill="{DynamicResource WindowBackground}"
                                                SnapsToDevicePixels="False"
                                                Stroke="{DynamicResource WindowBorderBrush}"
                                                StrokeThickness="1" />
                                        </Grid>

                                    </Border>
                                </Popup>
                                <Border
                                    x:Name="AverageTick"
                                    VerticalAlignment="Bottom"
                                    Panel.ZIndex="3"
                                    Background="Transparent"
                                    BorderThickness="2"
                                    CornerRadius="2"
                                    Cursor="Hand"
                                    Visibility="{TemplateBinding AverageVisibility}">
                                    <Border.BorderBrush>
                                        <SolidColorBrush Opacity=".6" Color="Transparent" />
                                    </Border.BorderBrush>

                                    <Rectangle
                                        x:Name="test"
                                        Height="2"
                                        Fill="#82D29A"
                                        RadiusX="2"
                                        RadiusY="2" />
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="AverageTickMouseEnter">

                                                <Storyboard>
                                                    <ColorAnimationUsingKeyFrames Storyboard.TargetName="AverageTick" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)">
                                                        <EasingColorKeyFrame KeyTime="0" Value="#4f6bed" />
                                                    </ColorAnimationUsingKeyFrames>

                                                </Storyboard>
                                            </VisualState>
                                            <VisualState Name="AverageTickMouseLeave" />
                                            <VisualStateGroup.Transitions>


                                                <VisualTransition GeneratedDuration="00:00:00.5" To="AverageTickMouseEnter">
                                                    <VisualTransition.GeneratedEasingFunction>
                                                        <ExponentialEase EasingMode="EaseOut" Exponent="10" />
                                                    </VisualTransition.GeneratedEasingFunction>
                                                </VisualTransition>

                                            </VisualStateGroup.Transitions>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                </Border>

                                <!--  底部刻度  -->
                                <Popup
                                    x:Name="BottomPopup"
                                    AllowsTransparency="True"
                                    HorizontalOffset="-10"
                                    Placement="Top"
                                    PlacementTarget="{Binding ElementName=BottomTick}"
                                    VerticalOffset="-10">
                                    <Border
                                        Margin="15"
                                        Padding="10"
                                        Background="{DynamicResource WindowBackground}"
                                        BorderBrush="{DynamicResource WindowBorderBrush}"
                                        BorderThickness="1">
                                        <Border.Effect>
                                            <DropShadowEffect
                                                BlurRadius="5"
                                                Opacity="0.2"
                                                ShadowDepth="1" />
                                        </Border.Effect>
                                        <Grid>
                                            <TextBlock>
                                                <Run Text="{DynamicResource Lang_Minimum}" />
                                                <Run Text="{TemplateBinding MinimumText}" />
                                            </TextBlock>
                                            <Path
                                                Width="15"
                                                Height="15"
                                                Margin="-5,0,0,-25"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Bottom"
                                                Data="M 0 0 L 7.5 7.5 L 15 0"
                                                Fill="{DynamicResource WindowBackground}"
                                                SnapsToDevicePixels="False"
                                                Stroke="{DynamicResource WindowBorderBrush}"
                                                StrokeThickness="1" />
                                        </Grid>

                                    </Border>
                                </Popup>
                                <Border
                                    x:Name="BottomTick"
                                    VerticalAlignment="Bottom"
                                    Panel.ZIndex="1"
                                    Background="Transparent"
                                    BorderThickness="2"
                                    CornerRadius="2"
                                    Cursor="Hand">
                                    <Border.BorderBrush>
                                        <SolidColorBrush Opacity=".6" Color="Transparent" />
                                    </Border.BorderBrush>

                                    <Rectangle
                                        Height="2"
                                        Fill="#f3f2f1"
                                        RadiusX="2"
                                        RadiusY="2" />
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="BottomTickMouseEnter">

                                                <Storyboard>
                                                    <ColorAnimationUsingKeyFrames Storyboard.TargetName="BottomTick" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)">
                                                        <EasingColorKeyFrame KeyTime="0" Value="#4f6bed" />
                                                    </ColorAnimationUsingKeyFrames>

                                                </Storyboard>
                                            </VisualState>
                                            <VisualState Name="BottomTickMouseLeave" />
                                            <VisualStateGroup.Transitions>


                                                <VisualTransition GeneratedDuration="00:00:00.5" To="BottomTickMouseEnter">
                                                    <VisualTransition.GeneratedEasingFunction>
                                                        <ExponentialEase EasingMode="EaseOut" Exponent="10" />
                                                    </VisualTransition.GeneratedEasingFunction>
                                                </VisualTransition>

                                            </VisualStateGroup.Transitions>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                </Border>
                                <ScrollViewer
                                    x:Name="ItemsScrollViewer"
                                    HorizontalScrollBarVisibility="Auto"
                                    OverridesDefaultStyle="True">
                                    <StackPanel x:Name="Container" Orientation="Horizontal" />
                                </ScrollViewer>
                                <Button
                                    x:Name="ScrollLeftButton"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Panel.ZIndex="3"
                                    Background="White"
                                    ContentStringFormat="&#xE72B;"
                                    Style="{StaticResource ScrollButton}"
                                    Visibility="{TemplateBinding ScrollLeftButtonVisibility}" />
                                <Button
                                    x:Name="ScrollRightButton"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Panel.ZIndex="3"
                                    Background="White"
                                    ContentStringFormat="&#xE72A;"
                                    Style="{StaticResource ScrollButton}"
                                    Visibility="{TemplateBinding ScrollRightButtonVisibility}" />
                            </Grid>

                        </Grid>
                    </Border>
                    <!--<ControlTemplate.Triggers>-->
                    <!--<Trigger Property="Show" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard Storyboard="{StaticResource ShowAnimation}">
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard Storyboard="{StaticResource CloseAnimation}">
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>-->

                </ControlTemplate>
            </Setter.Value>
        </Setter>

    </Style>


</ResourceDictionary>