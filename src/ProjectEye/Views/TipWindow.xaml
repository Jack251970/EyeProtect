<ui:Project1UIWindow
    x:Class="ProjectEye.Views.TipWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ProjectEye.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="clr-namespace:Project1.UI.Controls;assembly=Project1.UI"
    Title="TipWindow"
    Width="100"
    Height="100"
    AllowsTransparency="True"
    Background="Transparent"
    InputMethod.IsInputMethodEnabled="False"
    IsAnimation="{Binding IsAnimation}"
    IsThruWindow="{Binding IsThruWindow}"
    Opacity="1"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    Visibility="Hidden"
    WindowAnimationType="{Binding WindowAnimationType}"
    WindowStyle="None"
    mc:Ignorable="d">
