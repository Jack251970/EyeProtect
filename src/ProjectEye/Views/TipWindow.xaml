<Window
    x:Class="ProjectEye.Views.TipWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ProjectEye.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:gif="http://wpfanimatedgif.codeplex.com"
    Title="TipWindow"
    Width="100"
    Height="100"
    AllowsTransparency="True"
    Background="Transparent"
    InputMethod.IsInputMethodEnabled="False"
    Opacity="1"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    Visibility="Hidden"
    WindowStyle="None"
    mc:Ignorable="d">
    <Grid>
        <Border
            Opacity="{Binding ContainerOpacity}"
            Background="{Binding ContainerBackground}">
        </Border>
        
        <Grid VerticalAlignment="Center" Width="400">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            
            <!-- Eye protection image -->
            <Image
                Grid.Row="0"
                Width="272"
                Height="187"
                Margin="0,20,0,10"
                HorizontalAlignment="Center"
                gif:ImageBehavior.AnimatedSource="{Binding TipImageSource}"
                Stretch="UniformToFill" />
            
            <!-- Tip message text -->
            <TextBlock
                Grid.Row="1"
                Margin="0,10,0,0"
                HorizontalAlignment="Center"
                FontSize="20"
                TextWrapping="Wrap"
                TextAlignment="Center"
                Text="{Binding TipContent}" />
            
            <!-- Action buttons -->
            <StackPanel
                Grid.Row="2"
                Margin="0,20,0,0"
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Visibility="{Binding TakeButtonVisibility}">
                <Button
                    Width="110"
                    Height="45"
                    FontSize="14"
                    Command="{Binding resetCommand}"
                    Content="{DynamicResource Lang_Yes}" />
                <Button
                    Width="110"
                    Height="45"
                    Margin="10,0,0,0"
                    FontSize="14"
                    Command="{Binding busyCommand}"
                    Content="{DynamicResource Lang_No}" />
            </StackPanel>
            
            <!-- Countdown display -->
            <TextBlock
                Grid.Row="3"
                Margin="0,10,0,20"
                HorizontalAlignment="Center"
                FontSize="50"
                FontWeight="Bold"
                Text="{Binding COUNTDOWN}"
                Visibility="{Binding CountDownVisibility}" />
        </Grid>
    </Grid>
</Window>