<ui:Project1UIWindow
    x:Class="ProjectEye.Views.UpdateWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ProjectEye.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="clr-namespace:Project1.UI.Controls;assembly=Project1.UI"
    Title="{DynamicResource Lang_Updateprogram}"
    Width="500"
    Height="300"
    Icon="/ProjectEye;component/Resources/sunglasses.ico"
    ResizeMode="CanMinimize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <ui:Project1UIWindow.ExtElement>
        <ui:Project1UIModal Show="{Binding ShowModal, Mode=TwoWay}">
            <Border
                Margin="10"
                Padding="10,15"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="2">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="5"
                        Opacity="0.3"
                        ShadowDepth="0" />
                </Border.Effect>

                <TextBlock Text="{Binding ModalText}" />
            </Border>
        </ui:Project1UIModal>
    </ui:Project1UIWindow.ExtElement>
    <Grid>
        <Grid Panel.ZIndex="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*" />
                <RowDefinition Height="1*" />
                <RowDefinition Height="1*" />

            </Grid.RowDefinitions>
            <Grid>
                <ScrollViewer Margin="10">
                    <StackPanel>
                        <TextBlock
                            FontSize="15"
                            FontWeight="Bold"
                            Text="{Binding Tip}" />
                        <TextBlock Margin="0,10,0,0" Text="{Binding VersionInfo}" />
                        <TextBlock Margin="0,10,0,0" Visibility="{Binding OpenUrlVisibility}"><Hyperlink
                                Command="{Binding openurlCommand}"
                                CommandParameter="{Binding VersionUrl}"
                                ToolTip="{DynamicResource Lang_Viewinwebbrowser}">
                                <Run Text="{DynamicResource Lang_Viewwhatsnewintheupdate}" />
                            </Hyperlink></TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
            <ui:Project1UIProcessBar
                Grid.Row="1"
                Width="auto"
                Margin="10"
                IsPlay="{Binding PlayProcess}"
                PointColor="{DynamicResource ThemeBrush}"
                PointRadius="10" />
            <StackPanel
                Grid.Row="2"
                Margin="10,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <ui:Project1UIButton
                    Width="auto"
                    Padding="10,0"
                    Command="{Binding updateCommand}"
                    Content="{DynamicResource Lang_Downloadupdate}"
                    Visibility="{Binding UpVisibility}" />
                <ui:Project1UIButton
                    Width="auto"
                    Padding="10,0"
                    Command="{Binding installCommand}"
                    Content="{DynamicResource Lang_Installupdate}"
                    Visibility="{Binding InstallVisibility}" />
            </StackPanel>
        </Grid>
        <Image
            x:Name="img"
            Width="80"
            Height="80"
            Margin="50"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Panel.ZIndex="-1"
            Opacity=".5"
            RenderTransformOrigin="0.5,0.5"
            Source="/ProjectEye;component/Resources/gear_2699.png">
            <Image.RenderTransform>
                <TransformGroup>
                    <RotateTransform Angle="0" />
                </TransformGroup>
            </Image.RenderTransform>
            <Image.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation
                                Storyboard.TargetName="img"
                                Storyboard.TargetProperty="RenderTransform.Children[0].Angle"
                                From="0"
                                To="360"
                                Duration="0:0:59" />

                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Image.Triggers>
        </Image>
    </Grid>
</ui:Project1UIWindow>
