<Window
    x:Class="ProjectEye.Views.SkipNotificationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ProjectEye.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:vm="clr-namespace:ProjectEye.ViewModels"
    Title="SkipNotificationWindow"
    Width="320"
    Height="100"
    d:DataContext="{d:DesignInstance vm:SkipNotificationViewModel}"
    AllowsTransparency="True"
    Background="Transparent"
    InputMethod.IsInputMethodEnabled="False"
    Opacity="1"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    Visibility="Hidden"
    WindowStyle="None"
    mc:Ignorable="d">
    <Border
        Padding="15"
        Background="{Binding ContainerBackground}"
        BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="8"
        Opacity="{Binding ContainerOpacity}">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="15"
                Direction="270"
                Opacity="0.3"
                ShadowDepth="2"
                Color="Black" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Message text  -->
            <TextBlock
                Grid.Row="0"
                FontSize="14"
                FontWeight="SemiBold"
                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                Text="{Binding Message}"
                TextWrapping="Wrap" />

            <!--  Reason text  -->
            <TextBlock
                Grid.Row="1"
                Margin="0 5 0 0"
                FontSize="12"
                Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                Text="{Binding Reason}"
                TextWrapping="Wrap" />
        </Grid>
    </Border>
</Window>
