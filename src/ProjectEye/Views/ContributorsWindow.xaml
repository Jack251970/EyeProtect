<Window
    x:Class="ProjectEye.Views.ContributorsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ProjectEye.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    Title="{DynamicResource Lang_Contributors}"
    Width="360"
    Height="450"
    ui:WindowHelper.UseModernWindowStyle="True"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.Background>
            <ImageBrush
                ImageSource="/ProjectEye;component/Resources/ecology.png"
                Opacity="0.5"
                Stretch="UniformToFill" />
        </Grid.Background>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock
                    FontSize="14"
                    FontWeight="Bold"
                    Text="{DynamicResource Lang_Translators}" />
                <TextBlock Margin="0 10 0 0" TextWrapping="Wrap">
                    <Run Text="Author" />
                    <Hyperlink Command="{Binding openurlCommand}" CommandParameter="https://github.com/Planshit">Planshit</Hyperlink>
                </TextBlock>
                <TextBlock Margin="0 5 0 0" TextWrapping="Wrap">
                    <Run Text="Forker" />
                    <Hyperlink Command="{Binding openurlCommand}" CommandParameter="https://github.com/Jack251970">Jack251970</Hyperlink>
                </TextBlock>
                <TextBlock Margin="0 5 0 0" TextWrapping="Wrap">
                    <Run Text="English" />
                    <Hyperlink Command="{Binding openurlCommand}" CommandParameter="https://github.com/mr-south-guo">mr-south-guo</Hyperlink>
                </TextBlock>
                <TextBlock Margin="0 5 0 0" TextWrapping="Wrap">
                    <Run Text="English" />
                    <Hyperlink Command="{Binding openurlCommand}" CommandParameter="https://github.com/hiliangchunrui">hiliangchunrui</Hyperlink>
                </TextBlock>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
